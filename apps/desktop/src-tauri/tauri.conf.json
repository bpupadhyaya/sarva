{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Sarva",
  "version": "0.1.0",
  "identifier": "io.github.bpupadhyaya.sarva",
  "build": {
    "frontendDist": "http://127.0.0.1:8000",
    "devUrl": "http://127.0.0.1:8000"
  },
  "app": {
    "windows": [
      {
        "title": "Sarva",
        "width": 900,
        "height": 680,
        "minWidth": 480,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
